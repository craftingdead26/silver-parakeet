<?xml version="1.0"?>
<Container version="2">
  <Name>Chaptarr</Name>
  <Repository>robertlordhood/chaptarr:latest</Repository>
  <Registry>https://registry.hub.docker.com/r/robertlordhood/chaptarr</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <ReadMe/>
  <Overview>Chaptarr is an ebook and audiobook  management tool that integrates with the *arr ecosystem. It helps manage and organize book metadata.</Overview>
  <Category>MediaApp:Books</Category>
  <WebUI>http://[IP]:[PORT:8789]/</WebUI>
  <TemplateURL/>
  <Icon/>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>1767917935</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="config" Target="/config" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/chaptarr/config</Config>
  <Config Name="Audiobooks location" Target="/audiobooks" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/Media/Audio/Audiobooks</Config>
  <Config Name="ebooks" Target="/ebooks" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/Media/ebooks</Config>
  <Config Name="Downloads" Target="/downloads" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/Downloads/Complete/Audiobooks</Config>
  <Config Name="Default Port" Target="8789" Default="8789" Mode="tcp" Description="" Type="Port" Display="always" Required="false" Mask="false">8789</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">100</Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">99</Config>
  <Config Name="UMASK" Target="UMASK" Default="002" Mode="" Description="" Type="Variable" Display="always" Required="false" Mask="false">002</Config>
  <Config Name="TZ" Target="TZ" Default="Europe/London" Mode="" Description="Timezone" Type="Variable" Display="advanced" Required="true" Mask="false">Europe/London</Config>
  <Config Name="PostgreSQL Host" Target="Chaptarr__Postgres__Host" Default="" Mode="" Description="PostgreSQL server hostname or IP (leave blank to use SQLite)" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="PostgreSQL Port" Target="Chaptarr__Postgres__Port" Default="5432" Mode="" Description="PostgreSQL server port (default: 5432)" Type="Variable" Display="advanced" Required="false" Mask="false">5432</Config>
  <Config Name="PostgreSQL User" Target="Chaptarr__Postgres__User" Default="" Mode="" Description="PostgreSQL username" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="PostgreSQL Password" Target="Chaptarr__Postgres__Password" Default="" Mode="" Description="PostgreSQL password" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="PostgreSQL Main DB" Target="Chaptarr__Postgres__MainDb" Default="chaptarr-main" Mode="" Description="Main database name (default: chaptarr-main)" Type="Variable" Display="advanced" Required="false" Mask="false">chaptarr-main</Config>
  <Config Name="PostgreSQL Log DB" Target="Chaptarr__Postgres__LogDb" Default="chaptarr-log" Mode="" Description="Log database name (default: chaptarr-log)" Type="Variable" Display="advanced" Required="false" Mask="false">chaptarr-log</Config>
  <Config Name="PostgreSQL Cache DB" Target="Chaptarr__Postgres__CacheDb" Default="chaptarr-cache" Mode="" Description="Cache database name (default: chaptarr-cache)" Type="Variable" Display="advanced" Required="false" Mask="false">chaptarr-cache</Config>
  <TailscaleStateDir/>
</Container>
